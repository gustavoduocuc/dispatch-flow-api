# Plantilla para desarrollo local: cp .env.example .env y ./run-prod o ./run-docker
# En EC2 las mismas variables (Oracle, S3, región) van en GitHub Secrets del pipeline,
# no hace falta copiar este archivo al servidor (ver docs/guia-despliegue-ec2.md).

SPRING_DATASOURCE_URL=jdbc:oracle:thin:@dispatchflowdb_high
SPRING_DATASOURCE_USERNAME=tu_usuario
SPRING_DATASOURCE_PASSWORD=tu_password
TNS_ADMIN=./Wallet_DISPATCHFLOWDB

AWS_REGION=us-east-1
S3_BUCKET_NAME=dispatch-flow-prod
EFS_BASE_PATH=/app/efs

# --- EFS: según cómo ejecutas la app ---
#
# ./run-prod (local, Oracle + S3 reales, sin montar AWS EFS):
#   EFS_BASE_PATH=./tmp/efs
#
# ./run-prod probando contra EFS real en tu máquina (opcional):
#   1) sudo -E ./scripts/setup-efs-mount.sh  (ver disclaimer en el script)
#   2) EFS_BASE_PATH=/mnt/dispatch-flow-efs   o la ruta que hayas montado
#   Variables del script: EFS_FILE_SYSTEM_ID=fs-xxxxxxxx  AWS_REGION=us-east-1
#
# EC2 + Docker Hub: EFS_BASE_PATH=/app/efs ya lo fija el pipeline en docker run.
#   En el host solo monta el filesystem (docs/configuracion-efs-ec2.md), sin setup-efs-mount.sh.

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
